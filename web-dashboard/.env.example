# Backend API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# WebSocket Configuration (set to false for Vercel deployment)
NEXT_PUBLIC_WEBSOCKETS_ENABLED=false

# Supabase Configuration (REQUIRED for real-time messaging)
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Mapbox (for maps)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Optional: Stripe (for payments)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=your_stripe_public_key_here
